# Neon PostgreSQL — console.neon.tech → Connection Details → select "Prisma"
# Pooled URL (used at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct URL (used for migrations — same URL but without -pooler in hostname)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Cloudflare R2 — Dashboard → R2 → your bucket → Manage R2 API Tokens
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_bucket_name"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# Admin Dashboard — SESSION_SECRET must be 32+ characters
ADMIN_EMAIL="admin@yourorg.com"
ADMIN_PASSWORD="choose-a-strong-password"
SESSION_SECRET="at-least-32-characters-long-random-string-here"
